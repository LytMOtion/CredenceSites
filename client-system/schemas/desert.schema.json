    "dining": { "type": "object", "properties": { "heading": {"type":"string"}, "body": {"type":"string"} } },
    "wellness": { "type": "object", "properties": { "heading": {"type":"string"}, "body": {"type":"string"} } },
    "groupsEvents": { "type": "object", "properties": { "heading": {"type":"string"}, "body": {"type":"string"} } },
    "storyPlace": { "type": "object", "properties": { "heading": {"type":"string"}, "body": {"type":"string"} } }
  }
