      "rows": { "type": "array", "items": { "type": "object", "properties": { "label": {"type":"string"}, "detail": {"type":"string"}, "price": {"type":"string"} } } } } },
    "courseConditions": { "type": "object", "properties": { "status": {"type":"string"}, "cartRule": {"type":"string"}, "practice": {"type":"string"}, "weather": {"type":"string"} } },
    "stayLodging": { "type": "object", "properties": { "heading": {"type":"string"}, "body": {"type":"string"} } },
